# ===== Banco de dados (PostgreSQL) =====
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/casamento
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres123

# ===== Segurança =====
# Gere uma chave longa e secreta (mínimo 32 caracteres) para cada casamento
JWT_SECRET=troque-esta-chave-secreta-por-uma-bem-longa-e-aleatoria-123456
JWT_EXPIRATION_MS=2592000000

# ===== Frontend permitido (CORS) =====
FRONTEND_ORIGIN=http://localhost:3000

# ===== Cloudinary (armazenamento de fotos e vídeos) =====
# Crie uma conta grátis em https://cloudinary.com e copie do Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===== Limites de upload (opcional) =====
MAX_IMAGE_MB=10
MAX_VIDEO_MB=100
